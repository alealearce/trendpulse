# ── Supabase (create new project at supabase.com) ────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Spotify (free — developer.spotify.com → Create App) ──────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Reddit (free — reddit.com/prefs/apps → Create App → script) ──────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendPulse:v1.0

# ── Resend (email delivery) ───────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=trends@trendpulse.club

# ── Anthropic (for AI-generated "why it's early" blurbs — optional for MVP) ──
ANTHROPIC_API_KEY=

# ── Stripe (for Pro subscriptions — added in Week 2) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
